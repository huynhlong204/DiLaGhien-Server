datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==== USERS AND AUTH ====
model users {
  user_id           Int                  @id @default(autoincrement())
  email             String               @unique
  password_hash     String
  role_id           Int
  company_id        Int?
  phone             String
  token             String?
  created_at        DateTime             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime             @updatedAt @db.Timestamptz(6)
  roles             roles                @relation("users_roles", fields: [role_id], references: [role_id])
  transport_company transport_companies? @relation("users_transport_companies", fields: [company_id], references: [id], onDelete: SetNull)
  sessions          session[]
  driving_trips     trips[]              @relation("TripDriver")

  @@index([role_id])
  @@index([company_id])
  @@map("users")
}

model session {
  id           Int      @id @default(autoincrement())
  user_id      Int
  token        String   @unique
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  expires_at   DateTime @db.Timestamptz(6)
  is_active    Boolean  @default(true)
  last_used_at DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("session")
}

// ==== TRANSPORT COMPANIES ====
model transport_companies {
  id                    Int                     @id @default(autoincrement())
  name                  String
  avatar_url            String?
  tax_code              String                  @unique
  address               String
  contact_person        String
  db_connection_string  String?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  trips                 trips[]
  users                 users[]                 @relation("users_transport_companies")
  vehicles              vehicles[]
  seat_layout_templates seat_layout_templates[] @relation("TransportCompanyToSeatLayoutTemplate")
  company_routes        company_routes[]

  @@index([tax_code])
  @@map("transport_companies")
}

// ==== ROLES & PERMISSIONS ====
model roles {
  role_id                 Int                       @id @default(autoincrement())
  name                    String                    @unique
  description             String?
  users                   users[]                   @relation("users_roles")
  role_module_permissions role_module_permissions[]

  @@index([name])
  @@map("roles")
}

model modules {
  module_id               Int                       @id @default(autoincrement())
  name                    String                    @unique
  code                    String                    @unique
  description             String?
  permissions             permissions[]
  role_module_permissions role_module_permissions[]

  @@index([name])
  @@index([code])
  @@map("modules")
}

model permissions {
  permission_id Int     @id @default(autoincrement())
  module_id     Int
  name          String  @unique
  bit_value     Int
  description   String?
  modules       modules @relation(fields: [module_id], references: [module_id], onDelete: Cascade)

  @@index([module_id])
  @@map("permissions")
}

model role_module_permissions {
  role_id             Int
  module_id           Int
  permissions_bitmask Int
  roles               roles   @relation(fields: [role_id], references: [role_id])
  modules             modules @relation(fields: [module_id], references: [module_id])

  @@id([role_id, module_id])
  @@index([role_id])
  @@index([module_id])
  @@map("role_module_permissions")
}

// ==== CUSTOMERS ====
model customers {
  customer_id       Int                @id @default(autoincrement())
  email             String             @unique
  password_hash     String?
  phone             String?
  refresh_token_hash String?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @updatedAt @db.Timestamptz(6)
  customer_profiles customer_profiles?
  tickets           tickets[]
   reviews reviews[]
  interactions user_interactions[]

  @@index([email])
  @@map("customers")
}

model customer_profiles {
  id          Int       @id @default(autoincrement())
  customer_id Int       @unique
  avatar_url  String?
  gender      Boolean?
  dateOfBirth DateTime? @db.Timestamptz(6)
  name        String
  address     String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @updatedAt @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@index([customer_id])
  @@map("customer_profiles")
}

// ==== COMPANY ROUTES ====
model company_routes {
  id                  Int                   @id @default(autoincrement())
  company_id          Int
  route_id            Int
  approved            Boolean               @default(false)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  transport_companies transport_companies   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  routes              routes                @relation(fields: [route_id], references: [id], onDelete: Cascade)
  stops               company_route_stops[]
  trips               trips[]

  @@unique([company_id, route_id])
  @@map("company_routes")
}

model company_route_stops {
  id                  Int     @id @default(autoincrement())
  company_route_id    Int
  location_id         Int
  stop_order          Int
  is_pickup_point     Boolean @default(true)
  is_dropoff_point    Boolean @default(true)
  time_offset_minutes Int?    @default(0)

  company_route company_routes @relation(fields: [company_route_id], references: [id], onDelete: Cascade)
  location      locations      @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([company_route_id, stop_order])
  @@unique([company_route_id, location_id])
  @@map("company_route_stops")
}

// ==== VEHICLE LAYOUT & TYPES ====
model vehicle_types {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  vehicles vehicles[]
  trips    trips[]   @relation("TripVehicleType")

  @@map("vehicle_types")
}

model seat_layout_templates {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  seat_count  Int
  description String? @db.Text
  company_id  Int

  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  layout_data       Json?               @db.JsonB
  transport_company transport_companies @relation("TransportCompanyToSeatLayoutTemplate", fields: [company_id], references: [id])

  vehicles vehicles[]
  trips    trips[] // Triển khai mối quan hệ qua trips, nhưng trips cũng có thể có seat_layout_template_id nếu cần

  @@unique([name, company_id])
  @@map("seat_layout_templates")
}

model vehicles {
  id                      Int      @id @default(autoincrement())
  plate_number            String   @db.VarChar(50)
  brand                   String   @db.VarChar(100)
  status                  String   @default("active") @db.VarChar(50)
  company_id              Int
  vehicle_type_id         Int?
  seat_layout_template_id Int?
  created_at              DateTime @default(now()) @db.Timestamptz(6)
  updated_at              DateTime @updatedAt @db.Timestamptz(6)

  transport_company    transport_companies    @relation(fields: [company_id], references: [id])
  vehicle_type         vehicle_types?         @relation(fields: [vehicle_type_id], references: [id])
  seat_layout_template seat_layout_templates? @relation(fields: [seat_layout_template_id], references: [id])
  trips                trips[]

  @@unique([company_id, plate_number])
  @@map("vehicles")
}

// ==== LOCATION HIERARCHY ====
model locations {
  id                       Int                @id @default(autoincrement())
  name                     String
  address                  String
  province                 String?
  commune                  String?
  locationType             String?  
  map_url                  String?
  routesFrom               routes[]           @relation("RouteFrom")
  routesTo                 routes[]           @relation("RouteTo")
  shuttle_requests_pickup  shuttle_requests[] @relation("shuttle_requests_pickup")
  shuttle_requests_dropoff shuttle_requests[] @relation("shuttle_requests_dropoff")

  company_route_stops company_route_stops[]

  @@map("locations")
}

// ==== ROUTES ====
model routes {
  id               Int              @id @default(autoincrement())
  from_location_id Int
  to_location_id   Int
  estimated_time   String // Cân nhắc đổi thành Int (phút) nếu cần tính toán
  company_routes   company_routes[]
  from_location    locations        @relation("RouteFrom", fields: [from_location_id], references: [id], onDelete: Cascade)
  to_location      locations        @relation("RouteTo", fields: [to_location_id], references: [id], onDelete: Cascade)
  trips            trips[]

  @@unique([from_location_id, to_location_id])
  @@map("routes")
}

// ==== TRIPS ====
model trips {
  id               Int      @id @default(autoincrement())
  company_route_id Int
  vehicle_type_id         Int?
  vehicle_id       Int? // Đã sửa thành Int? để cho phép NULL
  driver_id        Int?
  departure_time   DateTime @db.Timestamptz(6)
  price_default    Float
  status           String   @db.VarChar(50)

  company_route company_routes @relation(fields: [company_route_id], references: [id], onDelete: Cascade)

  // Đã sửa thành optional (vehicles?) và onDelete: SetNull
 vehicle_type    vehicle_types? @relation("TripVehicleType", fields: [vehicle_type_id], references: [id])
  vehicles vehicles? @relation(fields: [vehicle_id], references: [id], onDelete: SetNull)
  tickets  tickets[]
  driver   users?    @relation("TripDriver", fields: [driver_id], references: [user_id], onDelete: SetNull)

  // Đã xóa các trường và quan hệ dư thừa sau đây
  // transport_companies         transport_companies? @relation(fields: [transport_companiesId], references: [id])
  // transport_companiesId       Int?
  // seat_layout_templates       seat_layout_templates? @relation(fields: [seat_layout_templatesId], references: [id])
  // seat_layout_templatesId     Int?
  // routes                      routes?              @relation(fields: [routesId], references: [id])
  // routesId                    Int?
  transport_companies     transport_companies?   @relation(fields: [transport_companiesId], references: [id])
  transport_companiesId   Int?
  seat_layout_templates   seat_layout_templates? @relation(fields: [seat_layout_templatesId], references: [id])
  seat_layout_templatesId Int?
  routes                  routes?                @relation(fields: [routesId], references: [id])
  routesId                Int?
   reviews reviews[]

  @@map("trips")
}

// ==== TICKETS & PAYMENTS ====
model tickets {
  id               Int                @id @default(autoincrement())
  code             String             @unique
  customer_id      Int?
  trip_id          Int
  seat_code        String
  booking_time     DateTime           @default(now()) @db.Timestamptz(6)
  status           String
  note             String?
   final_amount Float?
  payments         payments[]
  shuttle_requests shuttle_requests[]
  customers        customers?         @relation(fields: [customer_id], references: [customer_id], onDelete: SetNull)
  trips            trips              @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  ticket_details   ticket_details?

  @@unique([trip_id, seat_code])
  @@map("tickets")
}

model ticket_details {
  id              Int     @id @default(autoincrement())
  ticket_id       Int     @unique
  passenger_name  String
  passenger_phone String
  passenger_email String?
  ticket          tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@map("ticket_details")
}

model payments {
  id             Int      @id @default(autoincrement())
  ticket_id      Int
  method         String
  amount         Float
  status         String
  transaction_id String   @unique
  payment_time   DateTime @default(now()) @db.Timestamptz(6)
  tickets        tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ==== SHUTTLE ====
model shuttle_requests {
  id                  Int                   @id @default(autoincrement())
  ticket_id           Int
  pickup_location_id  Int
  dropoff_location_id Int
  status              String
  shuttle_assignments shuttle_assignments[]
  tickets             tickets               @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  locations_pickup    locations             @relation("shuttle_requests_pickup", fields: [pickup_location_id], references: [id], onDelete: Cascade)
  locations_dropoff   locations             @relation("shuttle_requests_dropoff", fields: [dropoff_location_id], references: [id], onDelete: Cascade)

  @@map("shuttle_requests")
}

model shuttle_assignments {
  id                 Int              @id @default(autoincrement())
  shuttle_request_id Int
  driver_id          Int?
  vehicle_plate      String?
  assigned_time      DateTime         @default(now()) @db.Timestamptz(6)
  status             String
  shuttle_requests   shuttle_requests @relation(fields: [shuttle_request_id], references: [id], onDelete: Cascade)

  @@map("shuttle_assignments")
}


model user_interactions {
  id          Int      @id @default(autoincrement())
  customer_id Int?     // Nullable cho khách vãng lai
  session_id  String   // Để nhóm các hành động trong 1 phiên
  event_type  String   // Ví dụ: 'search', 'view_trip', 'view_company'
  event_data  Json     // Lưu chi tiết: { "from": "HCM", "to": "Da Lat" } hoặc { "trip_id": 123 }
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  customer customers? @relation(fields: [customer_id], references: [customer_id])

  @@map("user_interactions")
}

model reviews {
  id          Int      @id @default(autoincrement())
  trip_id     Int
  customer_id Int
  rating      Int      // Điểm số từ 1 đến 5
  comment     String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  trip     trips     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  customer customers @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  @@unique([trip_id, customer_id]) // Mỗi khách chỉ đánh giá 1 chuyến 1 lần
  @@map("reviews")
}

model special_dates {
  date       DateTime @id @db.Date
  event_name String
  event_type String   // Ví dụ: 'public_holiday', 'school_vacation'

  @@map("special_dates")
}

model promotions {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  description      String
  discount_type    String   // 'percentage' hoặc 'fixed_amount'
  discount_value   Float
  valid_from       DateTime
  valid_to         DateTime
  is_active        Boolean  @default(true)
  usage_limit      Int?
  
  // Có thể thêm các quan hệ phức tạp hơn sau này 
  // Ví dụ: áp dụng cho tuyến nào, nhà xe nào...

  @@map("promotions")
}